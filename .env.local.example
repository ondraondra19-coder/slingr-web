# Doprava — Zásilkovna / Packeta (jediný dopravce — výdejní místa i doručení na adresu)
# NEXT_PUBLIC_PACKETA_API_KEY: veřejný klíč pro widget výdejních míst (zobrazuje se
#   v prohlížeči zákazníka). Získá se registrací na
#   https://client.packeta.com/cs/registration/choose-type (schválení do ~3 dnů),
#   klíč pak najdete po přihlášení kliknutím na jméno vpravo nahoře.
NEXT_PUBLIC_PACKETA_API_KEY=

# PACKETA_API_PASSWORD: soukromé API heslo pro vytváření zásilek (createPacket) —
#   NENÍ totéž co API klíč výše. Ze stejné administrace Packeta.
PACKETA_API_PASSWORD=

# Platba převodem — bankovní účet pro příjem plateb.
# POZOR: dokud tohle nevyplníte, stránka s potvrzením objednávky u platby
# převodem korektně ukáže "platba zatím není nastavena" místo falešného čísla
# účtu — NEVYPLŇUJTE svůj osobní účet bez domluvy s rodiči/zákonným zástupcem,
# pokud jde o reálný obchod (přijímání plateb za zboží je podnikání).
# NEXT_PUBLIC_BANK_ACCOUNT_DISPLAY: člověku čitelný tvar, např. "123456789/0800"
NEXT_PUBLIC_BANK_ACCOUNT_DISPLAY=
# NEXT_PUBLIC_BANK_ACCOUNT_IBAN: IBAN pro QR Platbu, např. "CZ6508000000192000145399"
#   (najdete v internetovém bankovnictví — detail účtu — nepočítejte si ho sami)
NEXT_PUBLIC_BANK_ACCOUNT_IBAN=
# NEXT_PUBLIC_BANK_NAME: jen popisek u čísla účtu, např. "Česká spořitelna"
NEXT_PUBLIC_BANK_NAME=

# NEXT_PUBLIC_SITE_URL: veřejná URL e-shopu — používá se v sitemap.xml,
# robots.txt a odkazech v transakčních e-mailech. Bez téhle proměnné se
# všude použije fallback "https://slingr.vercel.app" (Vercel doména), takže
# tohle je potřeba vyplnit jen po přechodu na jinou doménu
# (např. slingr.cz, až bude koupená a ověřená).
NEXT_PUBLIC_SITE_URL=

# Identifikace prodejce — zobrazí se v e-mailu o přijaté platbě
# (lib/email.ts, sellerBlock). Dokud NEXT_PUBLIC_SELLER_NAME není
# vyplněné, sekce se v e-mailu vůbec neukáže. NEXT_PUBLIC_SELLER_ICO
# může zůstat prázdné, dokud nemáte IČO vyřízené — pak se místo čísla
# poctivě ukáže "v procesu registrace" (nikdy si nevymýšlejte číslo,
# co by vypadalo jako reálné IČO). Aktuálně počítáno jako neplátce DPH;
# pokud se to změní, je potřeba upravit sellerBlock() v lib/email.ts
# (přidat DIČ a rozpis DPH), nestačí jen proměnná.
NEXT_PUBLIC_SELLER_NAME=
NEXT_PUBLIC_SELLER_ICO=
# NEXT_PUBLIC_SELLER_ADDRESS: nepovinné, adresa sídla podnikání
NEXT_PUBLIC_SELLER_ADDRESS=

# Newsletter — přihlášení z formuláře v patičce ukládá kontakty do Resend
# Audience (viz lib/newsletter.ts).
#
# RESEND_CONTACTS_API_KEY: klíč s oprávněním "Full access". Přidávání kontaktů
#   NEJDE odesílacím (sending-only) klíčem — Resend ho odmítne s 401
#   "restricted_api_key". Vytvoří se v Resend dashboardu: API Keys → Create →
#   Permission "Full access". Je to zvlášť od RESEND_API_KEY schválně, ať
#   odesílací klíč pro transakční poštu může zůstat jen sending-only. Pokud
#   tuhle proměnnou nevyplníte, kód spadne na RESEND_API_KEY — ten pak ale
#   musí být také full access.
RESEND_CONTACTS_API_KEY=
#
# RESEND_AUDIENCE_ID: VOLITELNÉ. Novější Resend účty mají jedinou výchozí
#   Audience bez zobrazeného ID — tuhle proměnnou nechte prázdnou a kontakt se
#   přidá rovnou do ní. Vyplňte jen na starších účtech s více Audiences
#   (Audiences → detail → ID z URL).
#
# Sběr kontaktů funguje i BEZ ověřené domény; rozesílání kampaní (Broadcasts)
# ale vyžaduje ověřenou doménu ve From adrese (stejný blocker jako transakční
# e-maily).
RESEND_AUDIENCE_ID=
#
# RESEND_CAMPAIGN_FROM: VOLITELNÉ. Odesílatel marketingových kampaní (admin →
#   Kampaně). Nechte prázdné a použije se RESEND_FROM_EMAIL (transakční). Kvůli
#   reputaci se doporučuje posílat marketing z jiné (pod)domény, např.
#   "SLINGR <news@slingr.cz>". Doména musí být ověřená v Resendu.
RESEND_CAMPAIGN_FROM=
